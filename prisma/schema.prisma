// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  NGO_REP
  DOCTOR
  PATIENT
  VOLUNTEER
  DONOR
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum CampaignStatus {
  DRAFT
  PENDING_NGO
  PENDING_ADMIN
  ACTIVE
  COMPLETED
  SUSPENDED
}

enum DocumentType {
  MEDICAL_BILL
  DIAGNOSIS_REPORT
  IDENTITY_PROOF
  NGO_LICENSE
  DOCTOR_CREDENTIAL
}

enum DonationStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
}

enum CertificateType {
  WEBINAR_ATTENDANCE
  QUIZ_EXCELLENCE
  VOLUNTEER_CAMPAIGN
}

model User {
  id            String        @id @default(uuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role          @default(VOLUNTEER)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  campaigns     Campaign[]
  donations     Donation[]
  certificates  Certificate[]
}

model Profile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber        String?
  avatarUrl          String?
  verificationStatus VerificationStatus @default(UNVERIFIED)
  rejectionReason    String?

  // Doctor specific fields
  medicalLicenseNumber String?
  hospitalAffiliation  String?
  specialty            String?

  // NGO specific fields
  ngoRegistrationNumber String?
  taxExemptionStatus80G Boolean            @default(false)
  websiteUrl            String?

  // Patient specific fields
  nationalIdNumber     String?            // Encrypted in production

  documents            Document[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Account {
  id                String   @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Campaign {
  id                   String         @id @default(uuid())
  patientId            String
  patient              User           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  title                String
  slug                 String         @unique
  description          String         @db.Text
  medicalSummary       String         @db.Text
  fundingGoal          Decimal        @db.Decimal(12, 2)
  amountRaised         Decimal        @default(0) @db.Decimal(12, 2)
  status               CampaignStatus @default(DRAFT)
  ngoEndorserId        String?
  hospitalName         String
  hospitalBankAccount  String         // Encrypted
  hospitalBankIFSC     String         // Encrypted
  documents            Document[]
  donations            Donation[]
  payouts              Payout[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}

model Document {
  id           String       @id @default(uuid())
  campaignId   String?
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  profileId    String?
  profile      Profile?     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  documentType DocumentType
  fileUrl      String
  isSecure     Boolean      @default(true)
  createdAt    DateTime     @default(now())
}

model Donation {
  id               String         @id @default(uuid())
  campaignId       String
  campaign         Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donorId          String?
  donor            User?          @relation(fields: [donorId], references: [id], onDelete: SetNull)
  amount           Decimal        @db.Decimal(12, 2)
  currency         String         @default("INR")
  paymentGatewayId String         @unique // Razorpay Payment ID / Order ID
  status           DonationStatus @default(PENDING)
  isAnonymous      Boolean        @default(false)
  createdAt        DateTime       @default(now())
}

model Payout {
  id                  String       @id @default(uuid())
  campaignId          String
  campaign            Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  amountRequested     Decimal      @db.Decimal(12, 2)
  hospitalInvoiceUrl  String
  status              PayoutStatus @default(PENDING)
  transactionReference String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model Certificate {
  id                  String          @id @default(uuid())
  recipientId         String
  recipient           User            @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  certificateType     CertificateType
  eventName           String
  certificateIdString String          @unique // e.g. GRS-2026-XXXX
  pdfStorageUrl       String
  verificationHash    String          @unique // Cryptographic Hash SHA-256
  createdAt           DateTime        @default(now())
}
